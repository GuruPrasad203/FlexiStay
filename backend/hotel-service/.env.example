# ─────────────────────────────────────────────
# Copy to .env and fill in values. Never commit .env to git.
# ─────────────────────────────────────────────

# Server
PORT=4002
NODE_ENV=development

# JWT — must match auth-service's JWT_ACCESS_SECRET so tokens are valid here too
JWT_ACCESS_SECRET=your_access_secret_here

# Database (PostgreSQL) — separate DB from auth-service
DATABASE_URL=postgresql://postgres:password@localhost:5432/flexistay_hotels

# Redis
REDIS_URL=redis://localhost:6379

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File uploads (hotel images)
# In production, point this to S3 or Cloudinary
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5
