# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in values
# Never commit .env.local to git
# ─────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend service URLs (running locally)
NEXT_PUBLIC_AUTH_API_URL=http://localhost:4001
NEXT_PUBLIC_HOTEL_API_URL=http://localhost:4002
NEXT_PUBLIC_NOTIFICATION_API_URL=http://localhost:4003
NEXT_PUBLIC_BOOKING_API_URL=http://localhost:4004

# Stripe (get from Stripe dashboard → Developers → API keys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# PostHog (analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=...
